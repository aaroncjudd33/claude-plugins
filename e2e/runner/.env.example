# SSO credentials — required if your app uses Microsoft SSO auto-login
SSO_EMAIL=you@example.com
SSO_PASS=yourpassword

# Domain used to identify the target page in the browser (e.g. youngliving.com, localhost)
TARGET_DOMAIN=

# Base URL for the app under test
BASE_URL=http://localhost:3000

# CDP port for browser remote debugging (default: 9222)
# CDP_PORT=9222

# Optional: HTTP Basic Auth
# HTTP_AUTH_USER=
# HTTP_AUTH_PASS=
